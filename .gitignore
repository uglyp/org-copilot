node_modules/
frontend/dist/
*.local

# TypeScript incremental / project references
*.tsbuildinfo

# vue-tsc 从 vite.config.ts 生成的产物（源码以 vite.config.ts 为准）
frontend/vite.config.js
frontend/vite.config.d.ts

# ——— OS / IDE ———
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Documentation: any directory named docs anywhere in the tree (never push)
**/docs/
