# 复制为 .env 并填写真实值（勿提交 .env）
#
# 关系库二选一（应用用异步 URL；Alembic 会映射为 mysql+pymysql / postgresql+psycopg）：
# - MySQL：mysql+aiomysql://...
# - PostgreSQL：postgresql+asyncpg://...
# 可选 RELATIONAL_DB=mysql 或 postgresql：与 DATABASE_URL 前缀一致时用于显式声明并做一致性校验（可不设）
#
# ---------- MySQL（与历史默认一致）----------
RELATIONAL_DB=mysql
DATABASE_URL=mysql+aiomysql://root:PASSWORD_URL_ENCODED@127.0.0.1:3306/kb_copilot
# 密码含特殊字符时请 URL 编码，例如 ! -> %21
# MySQL 8 若报 Public Key Retrieval is not allowed，在 URL 末尾追加：?allow_public_key_retrieval=true（若已有查询参数则用 &allow_public_key_retrieval=true）；应用会从 URL 中取出该参数并改为 connect_args 传入，避免部分环境下 SQLAlchemy 报错。
#
# ---------- PostgreSQL（与上一段二选一：注释掉 MySQL 两行后启用）----------
# RELATIONAL_DB=postgresql
# DATABASE_URL=postgresql+asyncpg://kbuser:PASSWORD@127.0.0.1:5432/kb_copilot
#
# 从 MySQL 迁数据到 PostgreSQL：先对 PG 库执行 alembic upgrade head，再运行
#   SYNC_SOURCE_DATABASE_URL=mysql+pymysql://... SYNC_TARGET_DATABASE_URL=postgresql+psycopg://... \
#   uv run python scripts/sync_relational_data.py --truncate-target

JWT_SECRET=change-me-use-openssl-rand-hex-32
FERNET_KEY=
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# 二选一：不设 MILVUS_URI 则使用 Milvus Lite 本地文件（MILVUS_DB_PATH）；设则连接独立 Milvus，例：http://127.0.0.1:19530
# MILVUS_URI=http://127.0.0.1:19530
# 可选：Zilliz Cloud / 开启鉴权的 Milvus
# MILVUS_TOKEN=
MILVUS_DB_PATH=./data/milvus_local.db
UPLOAD_DIR=./data/uploads
# 对话时向量召回条数（默认 12）
# RAG_TOP_K=12

# 仅开发：跳过模型就绪门禁（生产勿开）
ALLOW_CHAT_WITHOUT_MODEL_SETUP=false

# 本地向量（推荐）：无需远程 embedding API，首次运行会下载模型
USE_LOCAL_EMBEDDING=true
# LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# 国内下载 Hugging Face 模型易超时，建议取消下一行注释（与 hf-mirror.com 用法一致）
# HF_ENDPOINT=https://hf-mirror.com
# 单次下载/元数据超时（秒），默认已在代码里提高到 600/120，可按网络再调大
# HF_HUB_DOWNLOAD_TIMEOUT=600
# HF_HUB_ETAG_TIMEOUT=120

# ---------- 可选：PaddleOCR / 图片入库（uv sync --extra image）----------
# 安装 Python 包若 PyPI 慢，可在终端用国内源（示例）：
#   uv sync --extra image --default-index https://pypi.tuna.tsinghua.edu.cn/simple
# 或：export UV_DEFAULT_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
# Paddle 官方 wheel 若清华源不全，可改用百度源安装 paddlepaddle：
#   uv pip install paddlepaddle paddleocr -i https://mirror.baidu.com/pypi/simple
# PaddleOCR 首次运行会从百度 BOS 拉检测/识别模型（一般已在国内），仍失败请检查代理/防火墙。

# 可选：远程 OpenAI 兼容 embedding（USE_LOCAL_EMBEDDING=false 时生效，且会尝试自动创建提供商）
# EMBEDDING_API_KEY=
# EMBEDDING_API_BASE=https://api.openai.com
# EMBEDDING_MODEL=text-embedding-3-small

# 忘记密码：令牌有效时间（分钟）
# PASSWORD_RESET_TOKEN_TTL_MINUTES=60
# 无邮件服务时仅开发可设为 true，接口会返回 reset_token / reset_url（生产务必 false）
# PASSWORD_RESET_TOKEN_IN_RESPONSE=false
# 与上一项配合，用于拼前端重置页链接
# PASSWORD_RESET_FRONTEND_BASE=http://localhost:5173

# 可选：配置后，无 LLM 提供商的用户在注册/登录/拉取就绪状态时会自动创建 DeepSeek 对话模型
# DEEPSEEK_API_KEY=

# Ollama 本地对话（与 DeepSeek 并存）：配置后自动创建「非默认」chat，对话页可选本地模型（需本机 ollama serve 且已 pull）
# OLLAMA_BASE=http://127.0.0.1:11434
# OLLAMA_CHAT_MODEL=qwen2.5:3b

# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_CHAT_MODEL=deepseek-chat
